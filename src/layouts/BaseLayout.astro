---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Script Wizard' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-bg-dark text-text-primary font-mono min-h-screen relative">
    <div class="scanline-overlay"></div>
    <div class="relative z-10">
      <slot />
    </div>
  </body>
</html>
