---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'home' },
  { href: '/blog', label: 'blog' },
  { href: '/about', label: 'about' },
];
---

<header class="border-b border-neon-amber/40 bg-bg-surface/80 backdrop-blur-sm sticky top-0 z-40">
  <div class="max-w-5xl mx-auto px-4 flex items-center justify-between h-14">
    <!-- Logo / site title -->
    <a href="/" class="text-neon-amber text-lg font-bold tracking-wider hover:text-neon-cyan transition-colors">
      script_wizard<span class="cursor-blink">_</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm tracking-wide transition-colors',
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-neon-cyan'
              : 'text-text-muted hover:text-neon-amber',
          ]}
        >
          <span class="text-neon-amber/60">{'>'}</span> {link.label}<span class="text-neon-amber/40">_</span>
        </a>
      ))}
    </nav>

    <!-- Mobile hamburger toggle (CSS-only) -->
    <label for="mobile-menu-toggle" class="md:hidden cursor-pointer p-2 text-neon-amber" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="square" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </label>
  </div>

  <!-- Hidden checkbox for CSS-only mobile menu -->
  <input type="checkbox" id="mobile-menu-toggle" class="peer hidden" aria-hidden="true" />

  <!-- Mobile nav drawer -->
  <nav
    class="md:hidden max-h-0 overflow-hidden peer-checked:max-h-60 transition-all duration-300 border-t border-neon-amber/20"
    aria-label="Mobile navigation"
  >
    <ul class="flex flex-col px-4 py-2 gap-1">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              'block py-2 text-sm tracking-wide transition-colors',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-neon-cyan'
                : 'text-text-muted hover:text-neon-amber',
            ]}
          >
            <span class="text-neon-amber/60">{'>'}</span> {link.label}<span class="text-neon-amber/40">_</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .cursor-blink {
    animation: blink 1s step-end infinite;
  }
</style>
