---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-neon-amber/40 bg-bg-surface/80 mt-auto">
  <!-- Terminal decorative border -->
  <div class="max-w-5xl mx-auto px-4 pt-6 pb-2">
    <div class="text-neon-amber/20 text-xs select-none hidden sm:block text-center tracking-[0.5em]" aria-hidden="true">
      ═══════════════════════════════════════════
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 pb-6 flex flex-col sm:flex-row items-center justify-between gap-4">
    <!-- Copyright -->
    <p class="text-text-muted text-xs tracking-wide">
      <span class="text-neon-amber/60">&gt;</span> &copy; {currentYear} thescriptwizard<span class="text-neon-amber/40">_</span> <span class="text-text-muted/60">// all rights reserved</span>
    </p>

    <!-- Social links -->
    <nav class="flex items-center gap-4" aria-label="Social links">
      <a
        href="https://github.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-text-muted hover:text-neon-cyan transition-colors text-sm tracking-wide"
        aria-label="GitHub"
      >
        <span class="text-neon-amber/60">&gt;</span> github<span class="text-neon-amber/40">_</span>
      </a>
      <a
        href="https://x.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-text-muted hover:text-neon-cyan transition-colors text-sm tracking-wide"
        aria-label="X (Twitter)"
      >
        <span class="text-neon-amber/60">&gt;</span> x<span class="text-neon-amber/40">_</span>
      </a>
    </nav>
  </div>

  <!-- Attribution -->
  <div class="max-w-5xl mx-auto px-4 pb-4 text-center">
    <p class="text-text-muted/50 text-[10px] tracking-wide">
      Made with love by Avangarde Software Solutions
    </p>
  </div>
</footer>
