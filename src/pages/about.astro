---
import BaseLayout from '../layouts/BaseLayout.astro';

const skills = [
  { label: 'Scripting', value: 9, description: 'Bash, Python, PowerShell — automating everything' },
  { label: 'Persistence', value: 8, description: 'Debugging at 3 AM until the tests pass' },
  { label: 'Engineering', value: 7, description: 'Building systems that scale and last' },
  { label: 'CLI Craft', value: 9, description: 'The terminal is home' },
  { label: 'Integration', value: 8, description: 'Connecting APIs, services & pipelines' },
  { label: 'Automation', value: 10, description: 'If it can be automated, it will be' },
  { label: 'Linux', value: 8, description: 'Kernel configs, distro hopping, sysadmin' },
];

const tools = [
  'Bash', 'Python', 'TypeScript', 'Go',
  'Docker', 'Git', 'Ansible', 'Terraform',
  'Linux', 'Vim', 'tmux', 'CI/CD',
];
---

<BaseLayout title="About — The Script Wizard">
  <!-- Bio section -->
  <section class="max-w-5xl mx-auto px-4 pt-16 pb-12">
    <div class="border border-neon-amber/30 bg-bg-surface/60 p-6 sm:p-10">
      <p class="text-neon-amber/60 text-xs sm:text-sm mb-4 tracking-widest uppercase">// user profile loaded</p>
      <h1 class="text-neon-amber text-2xl sm:text-4xl font-bold tracking-wider mb-2">
        <span class="text-neon-amber/60">&gt;</span> about_me<span class="cursor-blink text-neon-cyan">_</span>
      </h1>
      <div class="mt-6 space-y-4 text-text-primary text-sm sm:text-base leading-relaxed">
        <p>
          <span class="text-neon-amber/60">&gt;</span> Hey there. I'm a developer who lives in the terminal
          and writes code to make machines do the boring stuff.
        </p>
        <p>
          <span class="text-neon-amber/60">&gt;</span> This blog is my digital notebook — a place to share scripts,
          automation tricks, and deep dives into the tools that make dev life better.
        </p>
        <p>
          <span class="text-neon-amber/60">&gt;</span> I believe in open source, reproducible environments,
          and the quiet satisfaction of a well-crafted shell script.
        </p>
      </div>
    </div>
  </section>

  <!-- Skill Proficiency section -->
  <section class="max-w-5xl mx-auto px-4 pb-12">
    <h2 class="text-neon-amber text-sm tracking-widest uppercase mb-6">
      <span class="text-neon-amber/60">&gt;</span> skill_proficiency<span class="text-neon-amber/40">_</span>
    </h2>

    <div class="border border-neon-amber/30 bg-bg-surface/60 p-6 sm:p-8">
      <div class="flex flex-col gap-5">
        {skills.map(skill => (
          <div class="flex flex-col gap-1">
            <div class="flex items-center justify-between">
              <span class="text-text-primary text-sm">{skill.label}</span>
              <span class="text-neon-amber/60 text-xs">{skill.value}/10</span>
            </div>
            <div class="w-full h-2 bg-bg-card border border-neon-amber/20">
              <div
                class="h-full bg-neon-amber/60"
                style={`width: ${skill.value * 10}%`}
              />
            </div>
            <p class="text-text-muted text-xs">{skill.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tools & Tech section -->
  <section class="max-w-5xl mx-auto px-4 pb-16">
    <h2 class="text-neon-cyan text-sm tracking-widest uppercase mb-6">
      <span class="text-neon-cyan/60">&gt;</span> equipped_tools<span class="text-neon-cyan/40">_</span>
    </h2>

    <div class="flex flex-wrap gap-3">
      {tools.map(tool => (
        <span class="border border-neon-cyan/30 bg-bg-card/60 text-neon-cyan text-xs sm:text-sm px-4 py-2 tracking-wide">
          {tool}
        </span>
      ))}
    </div>
  </section>

  <!-- Contact / Signal section -->
  <section class="max-w-5xl mx-auto px-4 pb-16">
    <h2 class="text-neon-magenta text-sm tracking-widest uppercase mb-6">
      <span class="text-neon-magenta/60">&gt;</span> open_channel<span class="text-neon-magenta/40">_</span>
    </h2>

    <div class="border border-neon-magenta/30 bg-bg-surface/60 p-6">
      <p class="text-text-muted text-sm leading-relaxed">
        <span class="text-neon-magenta/60">&gt;</span> Found a bug? Want to collaborate? Send a signal.
      </p>
      <div class="mt-4 flex flex-wrap gap-4">
        <a
          href="https://github.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-neon-magenta text-sm tracking-wide hover:text-neon-cyan transition-colors"
        >
          [GitHub]
        </a>
        <a
          href="https://x.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-neon-magenta text-sm tracking-wide hover:text-neon-cyan transition-colors"
        >
          [X/Twitter]
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .cursor-blink {
    animation: blink 1s step-end infinite;
  }
</style>
